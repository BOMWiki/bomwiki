{
  "name": "bomwiki-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The engine behind bomwiki.com: an openly editable, versioned encyclopedia of bills of materials.",
  "scripts": {
    "migrate": "node --experimental-strip-types scripts/migrate.ts",
    "export-graph": "npm exec --yes --package tsx -- tsx scripts/export-graph.mts",
    "import": "node --experimental-strip-types scripts/import.ts",
    "serve": "node --experimental-strip-types src/server.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "pg": "^8.16.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "@types/sanitize-html": "^2.16.1",
    "typescript": "^5.8.0"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/BOMWiki/bomwiki.git"
  }
}
