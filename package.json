{
  "name": "bomwiki-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "The engine behind bomwiki.com: an openly editable, versioned encyclopedia of bills of materials.",
  "scripts": {
    "migrate": "node --experimental-strip-types scripts/migrate.ts",
    "export-graph": "npm exec --yes --package tsx -- tsx scripts/export-graph.mts",
    "import": "node --experimental-strip-types scripts/import.ts",
    "serve": "node --experimental-strip-types src/server.ts",
    "typecheck": "tsc --noEmit",
    "studio:check": "node --experimental-strip-types scripts/studio-check.ts",
    "studio:v5:migration": "node --experimental-strip-types scripts/studio-v5-schema-check.ts",
    "studio:v5:runtime:document": "node --experimental-strip-types scripts/studio-v5-runtime-check.ts document",
    "studio:v5:runtime:kernel": "node --experimental-strip-types scripts/studio-v5-runtime-check.ts kernel",
    "studio:v5:runtime:browser": "node --experimental-strip-types scripts/studio-v5-runtime-check.ts browser",
    "studio:v5:runtime": "node --experimental-strip-types scripts/studio-v5-runtime-check.ts all",
    "studio:agent:protocol": "node --experimental-strip-types scripts/studio-agent-check.ts protocol",
    "studio:agent:queries": "node --experimental-strip-types scripts/studio-agent-check.ts queries",
    "studio:agent:transactions": "node --experimental-strip-types scripts/studio-agent-check.ts transactions",
    "studio:agent:headless": "node --experimental-strip-types scripts/studio-agent-headless-check.ts",
    "studio:agent:mcp": "node --experimental-strip-types scripts/studio-agent-mcp-check.ts",
    "studio:agent:parity": "node --experimental-strip-types scripts/studio-agent-browser-check.ts",
    "studio:agent:security": "node --experimental-strip-types scripts/studio-agent-check.ts security",
    "studio:agent:handoff": "node --experimental-strip-types scripts/studio-agent-check.ts handoff",
    "studio:agent:multibody": "node --experimental-strip-types scripts/studio-agent-check.ts multibody",
    "studio:agent:core": "node --experimental-strip-types scripts/studio-agent-check.ts all",
    "studio:agent:turbofan": "node --experimental-strip-types scripts/studio-agent-turbofan-check.ts",
    "studio:agent:release-check": "node --experimental-strip-types scripts/studio-agent-release-check.ts"
  },
  "dependencies": {
    "marked": "^18.0.5",
    "pg": "^8.16.0",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/pg": "^8.15.0",
    "@types/sanitize-html": "^2.16.1",
    "puppeteer": "^24.43.1",
    "typescript": "^5.8.0"
  },
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/BOMWiki/bomwiki.git"
  }
}
