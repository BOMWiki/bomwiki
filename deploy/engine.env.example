# /etc/bomwiki/engine.env — production environment for the BOMwiki engine.
# chmod 600, owned by root. Copy and fill in the secrets.

NODE_ENV=production
PORT=4400
DATABASE_URL=postgres://bomwiki:CHANGE-ME@localhost/bomwiki

# Operator sign-in (long random string; used at /login).
ADMIN_TOKEN=CHANGE-ME
ADMIN_HANDLE=sd

# Trust ladder: production wants account age in addition to accepted edits.
AUTOCONFIRM_EDITS=4
AUTOCONFIRM_DAYS=3

# Magic-link email (Resend-compatible HTTP API). Leaving MAIL_API_KEY empty
# disables email sign-in entirely (links are generated but never delivered)
# and makes all community email (welcome note, decision/reply notifications,
# the weekly digest) inert. DEV_SHOW_MAGIC_LINK must stay 0 in production —
# 1 is account takeover.
DEV_SHOW_MAGIC_LINK=0
MAIL_API_KEY=
MAIL_FROM=BOMwiki <signin@bomwiki.com>
SITE_ORIGIN=https://bomwiki.com

# Static assets from the old site's public/ tree (photos, thumbs, og cards).
PUBLIC_DIR=/opt/bomwiki/public
IMAGES_JSON=/opt/bomwiki/data/images.json
GALLERIES_JSON=/opt/bomwiki/data/galleries.json
# Cache-busting token for self-hosted images; CI sets this to the commit SHA.
PUBLIC_ASSET_VERSION=CHANGE-ME

# bomwiki-intelligence sidecar (optional; absent = no machine findings).
INTEL_URL=http://127.0.0.1:8799
INTEL_TIMEOUT_MS=4000

# Optional FFS graph sidecar (transitive where-used on part pages).
# Absent or down means the feature is simply hidden.
FFS_HOST=127.0.0.1
FFS_PORT=8464
FFS_TIMEOUT_MS=2500
